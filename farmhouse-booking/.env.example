# Booking API Configuration
# Used by src/data/media.ts → src/lib/api/client.ts

# Next.js: NEXT_PUBLIC_* variables are inlined at build time

# Booking API base URL (with /api path)
NEXT_PUBLIC_API_BASE_URL=

# Default Service ID (MongoDB ObjectId from backend)
# This is the _id returned by your backend when you create the service.
# Must be a 24-character hex string (e.g., 507f1f77bcf86cd799439011)
NEXT_PUBLIC_DEFAULT_SERVICE_ID=

# Farmhouse Contact Information
# These values are embedded in the marketing site footer, contact form, etc.

NEXT_PUBLIC_FARMHOUSE_PHONE=

NEXT_PUBLIC_FARMHOUSE_EMAIL=

NEXT_PUBLIC_FARMHOUSE_ADDRESS=

# Notes:
# - For local development (.env.local), set your own API base URL (e.g., http://localhost:5000/api)
# - Replace DEFAULT_SERVICE_ID with the actual service _id from your backend
# - For staging/preview deployments, update the API base URL and service ID
# - Fallback values in code ensure the app works if env vars are not set (using production defaults)
